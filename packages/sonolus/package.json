{
  "name": "@haneoka/sonolus",
  "version": "0.1.0",
  "description": "Runtime-neutral chart conversion and Sonolus service adapters",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haneoka-gakuen/haneoka.git",
    "directory": "packages/sonolus"
  },
  "bugs": {
    "url": "https://github.com/haneoka-gakuen/haneoka/issues"
  },
  "homepage": "https://github.com/haneoka-gakuen/haneoka/tree/main/packages/sonolus#readme",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "dist/index.d.ts.map",
    "dist/convert",
    "dist/runtime",
    "dist/shared",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=neutral --format=esm --target=es2022 --outfile=dist/index.js --external:@haneoka/sonolus-core --external:@sonolus/core && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "pnpm run typecheck && pnpm run build"
  },
  "dependencies": {
    "@haneoka/sonolus-core": "^0.1.0",
    "@sonolus/core": "^7.15.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "esbuild": "^0.21.5",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  }
}
