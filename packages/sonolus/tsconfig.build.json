{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "dist",
    "rootDir": "src"
  },
  "include": ["src/index.ts", "src/convert/**/*.ts", "src/runtime/**/*.ts", "src/shared/**/*.ts"],
  "exclude": ["src/server/**/*.ts"]
}
