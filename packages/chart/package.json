{
  "name": "@haneoka/chart",
  "version": "0.1.0",
  "description": "Browser chart parser, simulation engine, renderer, and Vue components for Haneoka",
  "keywords": [
    "rhythm-game",
    "chart",
    "three.js",
    "vue"
  ],
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haneoka-gakuen/haneoka.git",
    "directory": "packages/chart"
  },
  "bugs": {
    "url": "https://github.com/haneoka-gakuen/haneoka/issues"
  },
  "homepage": "https://github.com/haneoka-gakuen/haneoka/tree/main/packages/chart#readme",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "RUNTIME_FIDELITY.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./assets": {
      "types": "./dist/assets-entry.d.ts",
      "import": "./dist/assets.js",
      "default": "./dist/assets.js"
    },
    "./overview": {
      "types": "./dist/overview-entry.d.ts",
      "import": "./dist/overview.js",
      "default": "./dist/overview.js"
    },
    "./parser": {
      "types": "./dist/parser-entry.d.ts",
      "import": "./dist/parser.js",
      "default": "./dist/parser.js"
    },
    "./player": {
      "types": "./dist/player-entry.d.ts",
      "import": "./dist/player.js",
      "default": "./dist/player.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.build.json",
    "typecheck": "vue-tsc -p tsconfig.json --noEmit",
    "prepack": "pnpm run typecheck && pnpm run build"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "three": ">=0.184.0 <0.185.0",
    "vue": ">=3.5.0 <4"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/compiler-sfc": "^3.5.39",
    "three": "0.184.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.6",
    "vue": "3.5.39",
    "vue-tsc": "^3.3.6"
  }
}
