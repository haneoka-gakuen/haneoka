{
  "name": "@haneoka/chart-editor",
  "version": "0.1.0",
  "description": "Browser-neutral authored chart model, timing, validation, and format adapters",
  "keywords": [
    "rhythm-game",
    "chart-editor",
    "sus",
    "usc"
  ],
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haneoka-gakuen/haneoka.git",
    "directory": "packages/chart-editor"
  },
  "bugs": {
    "url": "https://github.com/haneoka-gakuen/haneoka/issues"
  },
  "homepage": "https://github.com/haneoka-gakuen/haneoka/tree/main/packages/chart-editor#readme",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "LICENSE",
    "LICENSE.next-sekai-editor.txt",
    "LICENSE.next-sekai.txt",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./formats": {
      "types": "./dist/formats/index.d.ts",
      "import": "./dist/formats.js",
      "default": "./dist/formats.js"
    },
    "./history": {
      "types": "./dist/history.d.ts",
      "import": "./dist/history.js",
      "default": "./dist/history.js"
    },
    "./model": {
      "types": "./dist/model.d.ts",
      "import": "./dist/model.js",
      "default": "./dist/model.js"
    },
    "./timing": {
      "types": "./dist/timing.d.ts",
      "import": "./dist/timing.js",
      "default": "./dist/timing.js"
    },
    "./validation": {
      "types": "./dist/validation.d.ts",
      "import": "./dist/validation.js",
      "default": "./dist/validation.js"
    },
    "./viewport": {
      "types": "./dist/viewport.d.ts",
      "import": "./dist/viewport.js",
      "default": "./dist/viewport.js"
    },
    "./waveform": {
      "types": "./dist/waveform.d.ts",
      "import": "./dist/waveform.js",
      "default": "./dist/waveform.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "pnpm run typecheck && pnpm run build"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "typescript": "^6.0.3",
    "vite": "^7.3.6"
  }
}
