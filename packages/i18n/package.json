{
  "name": "@haneoka/i18n",
  "version": "0.1.0",
  "description": "Browser-neutral locale matching, fallback, and message resolution for Haneoka applications",
  "keywords": [
    "i18n",
    "localization",
    "bcp47"
  ],
  "license": "MPL-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/haneoka-gakuen/haneoka.git",
    "directory": "packages/i18n"
  },
  "bugs": {
    "url": "https://github.com/haneoka-gakuen/haneoka/issues"
  },
  "homepage": "https://github.com/haneoka-gakuen/haneoka/tree/main/packages/i18n#readme",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./locales": {
      "types": "./dist/locales.d.ts",
      "import": "./dist/locales.js",
      "default": "./dist/locales.js"
    },
    "./content": {
      "types": "./dist/content.d.ts",
      "import": "./dist/content.js",
      "default": "./dist/content.js"
    },
    "./messages": {
      "types": "./dist/messages.d.ts",
      "import": "./dist/messages.js",
      "default": "./dist/messages.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "pnpm run typecheck && pnpm run build"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
